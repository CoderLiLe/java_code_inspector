{
  "rules": {
    "line_length": {
      "enabled": true,
      "max_length": 80
    },
    "naming_conventions": {
      "enabled": false
    },
    "unused_imports": {
      "enabled": true
    },
    "empty_methods": {
      "enabled": true
    },
    "magic_numbers": {
      "enabled": true
    }
  },
  "alibaba_naming": {
    "enabled": true
  },
  "alibaba_oop": {
    "enabled": true
  },
  "alibaba_control": {
    "enabled": true
  },
  "alibaba_collection": {
    "enabled": true
  },
  "alibaba_constant": {
    "enabled": true
  },
  "alibaba_method_length": {
    "enabled": true,
    "max_lines": 80
  },
  "alibaba_code_style": {
    "enabled": true
  },
  "alibaba_date": {
    "enabled": true
  },
  "alibaba_comment": {
    "enabled": true
  },
  "alibaba_exception": {
    "enabled": true
  },
  "alibaba_logging": {
    "enabled": true
  },
  "alibaba_other": {
    "enabled": true
  },
  "exclude_patterns": [
    "**/test/**"
  ]
}